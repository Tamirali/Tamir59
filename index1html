                        <g id="mouthOpenOverlay">
                            <ellipse cx="60" cy="36" rx="46" ry="20" fill="#42130e" />
                            <path d="M22 28 Q60 30 98 28 Q60 24 22 28Z" fill="#ffffff" />
                            <path d="M28 44 Q60 38 92 44 Q60 50 28 44Z" fill="#c95b53" />
                        </g>
                    </svg>
                </div>
            </div>
            <!-- NEWS TICKER -->
            <div class="news-ticker">
                <div class="ticker-title">BREAKING NEWS</div>
                <div class="ticker-text">तामीर अली विस्फोटक न्यूज़ पोर्टल में आपका स्वागत है... ताज़ा अपडेट्स के लिए बने रहें...</div>
            </div>
        </section>
        <!-- ─── CONTROLS PANEL ─── -->
        <section class="panel">
            <!-- ✅ SAVE BUTTON — MOVED TO TOP (above Face Upload) -->
            <button class="save-btn" id="saveBtn" disabled>
