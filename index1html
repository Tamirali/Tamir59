        .save-btn {
            background: var(--green);
            color: #fff;
            padding: 12px 20px;
            border-radius: 8px;
            font-weight: 700;
            font-size: 1rem;
            box-shadow: 0 2px 16px rgba(63, 117, 104, 0.3);
            transition: 0.2s;
            width: 100%;
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }
        .save-btn:active {
            transform: scale(0.97);
        }
        .save-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            box-shadow: none;
            transform: none;
        }
        .save-btn.has-video {
            background: #2d8f7a;
