                <b>🎯 होठों की स्थिति एडजस्ट करें</b>
                <div class="slider-group">
                    <div class="slider-item">L/R <input type="range" id="lipX" min="-50" max="50" value="0" /></div>
                    <div class="slider-item">U/D <input type="range" id="lipY" min="-50" max="50" value="0" /></div>
                    <div class="slider-item">Size <input type="range" id="lipScale" min="50" max="150" value="100" /></div>
                </div>
            </div>
            <!-- AUDIO UPLOAD -->
            <label class="upload-zone">
                🎵 ऑडियो फाइल चुनें (MP3, WAV)
                <input type="file" id="audioInput" accept="audio/*" hidden />
            </label>
            <!-- PLAYER -->
            <div class="player" id="player">
                <button id="playPauseButton" class="rec-btn" style="background:var(--green); width:100%; padding:10px; border-radius:8px; font-weight:bold; color:#fff;">▶ Play Audio</button>
            </div>
            <!-- GALLERY -->
            <div class="controls-box" style="max-height:200px; overflow-y:auto;">
                <b>📁 Saved Videos</b>
                <div id="galleryList" class="gallery-list">
                    <div class="empty-gallery">No saved videos yet.</div>
                </div>
            </div>
        </section>
        <!-- Hidden canvas for recording -->
        <canvas id="recordCanvas" class="hidden-canvas" width="380" height="470"></canvas>
        
        <!-- ✅ NEW GALLERY PLAYER OVERLAY (FIXED) -->
        <div class="player-overlay" id="playerOverlay">
            <div class="overlay-header">
                <h3 id="overlayVideoName">Video Player</h3>
                <button class="close-overlay-btn" id="closeOverlayBtn">✕</button>
