    <meta name="description" content="Tamir Ali Visfot News Vocal Lip Sync Portal" />
    <title>Tamir Ali Visfot News</title>
    <style>
        :root {
            --ink: #17332f;
            --ink-soft: #536863;
            --paper: #fbf5e9;
            --paper-deep: #eee2cc;
            --red: #bf4d3c;
            --red-deep: #8f332a;
            --gold: #e9b949;
            --green: #3f7568;
            --white: #fffdf7;
            --shadow: 0 24px 70px rgba(8, 31, 27, 0.32);
            --record-red: #e74c3c;
        }
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        html {
            min-width: 320px;
            background: #0a1f1b;
        }
        body {
            min-height: 100vh;
            min-height: 100dvh;
            display: grid;
            place-items: center;
            overflow-x: hidden;
            color: var(--ink);
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: #0a1f1b;
        }
        button,
        input {
            font: inherit;
        }
        button {
            cursor: pointer;
            border: none;
            outline: none;
        }
        .shell {
            position: relative;
            width: 100%;
            max-width: 520px;
            min-height: 100dvh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            background: var(--paper);
            box-shadow: var(--shadow);
            border-radius: 0;
        }
        @media (min-width: 600px) {
            .shell {
                border-radius: 32px 12px 32px 12px;
                min-height: min(920px, 100dvh);
                max-height: 98dvh;
                margin: 8px auto;
                box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5);
            }
        }
        /* ─── STAGE ─── */
        .stage {
            position: relative;
            flex: 0 0 auto;
            min-height: 460px;
            padding: clamp(20px, 4vw, 36px) clamp(16px, 3vw, 28px);
            overflow: hidden;
            color: var(--white);
            background: linear-gradient(180deg, rgba(13, 38, 34, 0.15), rgba(13, 38, 34, 0.70)), var(--green);
            border-bottom: 4px solid var(--gold);
        }
        .stage-mark {
            position: relative;
            z-index: 1;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 8px;
        }
        .stage-mark h1 {
            font-size: 1.1rem;
            font-weight: 700;
            color: #f5cf70;
            text-transform: uppercase;
            flex: 1;
            min-width: 120px;
        }
        .stage-top-actions {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-shrink: 0;
        }
        .rec-btn-top {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 6px 16px 6px 12px;
            border-radius: 99px;
            font-weight: 700;
            font-size: 0.7rem;
            color: #fff;
            background: var(--red);
            transition: all 0.25s ease;
            box-shadow: 0 4px 16px rgba(191, 77, 60, 0.35);
            border: 1px solid rgba(255, 255, 255, 0.15);
            white-space: nowrap;
        }
        .rec-btn-top:active {
            transform: scale(0.94);
        }
        .rec-btn-top .dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #fff;
            flex-shrink: 0;
            transition: all 0.3s ease;
        }
        .rec-btn-top.recording {
            background: var(--record-red);
            animation: pulse-rec-btn 1s infinite;
            box-shadow: 0 4px 24px rgba(231, 76, 60, 0.5);
        }
        .rec-btn-top.recording .dot {
            animation: pulse-dot 0.8s ease-in-out infinite;
        }
        @keyframes pulse-rec-btn {
            0%,
            100% {
                box-shadow: 0 4px 24px rgba(231, 76, 60, 0.5);
            }
            50% {
                box-shadow: 0 4px 40px rgba(231, 76, 60, 0.25);
            }
        }
        @keyframes pulse-dot {
            0%,
            100% {
                opacity: 1;
                transform: scale(1);
            }
            50% {
                opacity: 0.3;
                transform: scale(0.6);
            }
        }
        .rec-btn-top .badge {
            font-size: 0.5rem;
            background: rgba(255, 255, 255, 0.2);
            padding: 1px 8px;
            border-radius: 20px;
            color: rgba(255, 255, 255, 0.9);
            letter-spacing: 0.5px;
        }
        .rec-indicator {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 3px 10px;
            border-radius: 99px;
            background: rgba(0, 0, 0, 0.45);
            font-size: 0.55rem;
            color: rgba(255, 255, 255, 0.7);
            flex-shrink: 0;
        }
        .rec-indicator .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #666;
        }
        .rec-indicator.active .dot {
            background: var(--record-red);
            animation: pulse-rec 1s infinite;
        }
        @keyframes pulse-rec {
            50% {
                opacity: 0.4;
            }
        }
        .portrait-wrap {
            position: relative;
            width: clamp(220px, 60vw, 320px);
            margin: 10px auto 0;
            transform-origin: 50% 80%;
            border-radius: 16px;
        }
        .portrait-wrap img {
            display: block;
            width: 100%;
            height: auto;
            border-radius: 16px;
            object-fit: cover;
            aspect-ratio: 380 / 470;
        }
        .mouth-overlay {
            --lip-x: 0px;
            --lip-y: 0px;
            --lip-scale: 1;
            position: absolute;
            left: calc(50% + var(--lip-x));
            bottom: calc(18% + 38px + var(--lip-y));
            width: calc(28% * var(--lip-scale));
            height: calc(9% * var(--lip-scale));
            transform: translateX(-50%);
            z-index: 3;
        }
        .mouth-overlay svg {
            width: 100%;
            height: 100%;
        }
        #mouthOpenOverlay {
            opacity: 0;
            transform-origin: center;
        }
        #mouthClosedOverlay {
            opacity: 1;
            transform-origin: center;
        }
        .news-ticker {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            background: var(--red);
            color: #fff;
            display: flex;
            align-items: center;
            font-size: 0.75rem;
            font-weight: bold;
            overflow: hidden;
            border-top: 2px solid var(--gold);
        }
        .ticker-title {
            background: var(--gold);
            color: #000;
            padding: 4px 10px;
            white-space: nowrap;
            z-index: 2;
        }
        .ticker-text {
            white-space: nowrap;
            padding-left: 100%;
            display: inline-block;
            animation: marquee 12s linear infinite;
        }
        @keyframes marquee {
            0% {
                transform: translate(0, 0);
            }
            100% {
                transform: translate(-100%, 0);
            }
        }
        /* ─── PANEL ─── */
        .panel {
            flex: 1;
            display: flex;
            flex-direction: column;
            padding: 16px;
            background: var(--paper);
            overflow-y: auto;
            gap: 12px;
        }
        .controls-box {
            padding: 12px;
            border: 1px solid rgba(23, 51, 47, 0.1);
            border-radius: 12px;
            background: rgba(255, 253, 247, 0.7);
        }
        .slider-group {
            display: flex;
            gap: 8px;
            margin-top: 8px;
        }
        .slider-item {
            flex: 1;
            font-size: 0.65rem;
        }
        .slider-item input {
            width: 100%;
        }
        .upload-zone {
            border: 1.5px dashed #9a8d79;
            padding: 12px;
            text-align: center;
            border-radius: 8px;
            cursor: pointer;
            transition: background 0.2s;
            font-size: 0.9rem;
        }
        .upload-zone:hover {
            background: rgba(154, 141, 121, 0.06);
        }
        .player {
            display: none;
            margin-top: 8px;
        }
        .player.is-visible {
            display: block;
        }
        .save-btn {
            background: var(--green);
            color: #fff;
            padding: 12px 20px;
            border-radius: 8px;
            font-weight: 700;
            font-size: 1rem;
            box-shadow: 0 2px 16px rgba(63, 117, 104, 0.3);
            transition: 0.2s;
            width: 100%;
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }
        .save-btn:active {
            transform: scale(0.97);
        }
        .save-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            box-shadow: none;
            transform: none;
        }
        .save-btn.has-video {
            background: #2d8f7a;
            box-shadow: 0 2px 20px rgba(63, 117, 104, 0.5);
        }
        .gallery-list {
            max-height: 150px;
            overflow-y: auto;
            border-top: 1px solid rgba(0, 0, 0, 0.06);
            padding-top: 8px;
            margin-top: 4px;
        }
        .gallery-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 6px 4px;
            border-bottom: 1px solid rgba(0, 0, 0, 0.04);
            font-size: 0.7rem;
            gap: 6px;
        }
        .gallery-item .name {
            flex: 1;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .gallery-item .actions {
            display: flex;
            gap: 4px;
            flex-shrink: 0;
        }
        .gallery-item button {
            background: var(--red);
            color: #fff;
            padding: 2px 12px;
            border-radius: 20px;
            font-size: 0.6rem;
            transition: 0.15s;
        }
        .gallery-item button:active {
            transform: scale(0.92);
        }
        .gallery-item .play-btn {
            background: var(--green);
        }
        .gallery-item .del-btn {
            background: #b91c1c;
        }
        .empty-gallery {
            color: var(--ink-soft);
            font-size: 0.7rem;
            padding: 8px 0;
            text-align: center;
        }
        .hidden-canvas {
            position: absolute;
            top: -9999px;
            left: -9999px;
            width: 380px;
            height: 470px;
            pointer-events: none;
            opacity: 0;
        }
        .toast-msg {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0, 0, 0, 0.85);
            color: #fff;
            padding: 12px 24px;
            border-radius: 40px;
            font-size: 0.9rem;
            z-index: 999;
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            max-width: 90%;
            text-align: center;
            pointer-events: none;
            transition: opacity 0.3s;
        }
        .toast-msg.success {
            border-color: #6ee7b7;
        }
        .toast-msg.error {
            border-color: #fca5a5;
        }
        .toast-msg.info {
            border-color: #93c5fd;
        }
        
        /* ─── ✅ NEW GALLERY PLAYER OVERLAY (FIXED) ─── */
        .player-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.95);
            z-index: 2000;
            display: none; /* Hidden by default */
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
            color: #fff;
        }
        .player-overlay.is-visible {
            display: flex;
        }
        .overlay-header {
            width: 100%;
            max-width: 380px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }
        .overlay-header h3 {
            font-size: 1rem;
            font-weight: 700;
            color: var(--gold);
        }
        .close-overlay-btn {
            background: rgba(255, 255, 255, 0.15);
            color: #fff;
            border-radius: 50%;
            width: 36px;
            height: 36px;
            font-size: 1.2rem;
            display: grid;
            place-items: center;
        }
        .overlay-video-container {
            width: 100%;
            max-width: 380px; /* Keep correct ratio */
            aspect-ratio: 380 / 470;
            position: relative;
            background: #000;
            border-radius: 16px;
            overflow: hidden;
            border: 2px solid var(--gold);
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.8);
        }
        .overlay-video-container video {
            width: 100%;
            height: 100%;
            object-fit: contain; /* OR 'cover' if you prefer to fill the container */
        }
        .overlay-controls {
            margin-top: 15px;
            color: var(--ink-soft);
            font-size: 0.8rem;
        }
        
        @media (max-width: 420px) {
            .stage-mark h1 {
                font-size: 0.85rem;
                min-width: 80px;
            }
            .rec-btn-top {
                padding: 4px 12px 4px 10px;
                font-size: 0.6rem;
            }
            .rec-btn-top .badge {
                display: none;
            }
            .rec-indicator {
                font-size: 0.5rem;
                padding: 2px 8px;
            }
            .rec-indicator .dot {
                width: 6px;
                height: 6px;
            }
            .save-btn {
                font-size: 0.85rem;
                padding: 10px 16px;
            }
        }
        @media (max-width: 360px) {
            .stage-mark h1 {
                font-size: 0.7rem;
            }
            .rec-btn-top {
                font-size: 0.5rem;
                padding: 3px 8px 3px 6px;
                gap: 4px;
            }
            .rec-btn-top .dot {
                width: 6px;
                height: 6px;
            }
            .rec-indicator {
                display: none;
            }
        }
    </style>
</head>
