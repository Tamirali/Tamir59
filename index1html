    </main>
    <script>
        (function() {
            'use strict';
            // ─── DOM REFS ───
            const faceInput = document.getElementById('faceInput');
            const faceImage = document.getElementById('faceImage');
            const audioInput = document.getElementById('audioInput');
            const mouthOverlay = document.getElementById('mouthOverlay');
            const mouthOpen = document.getElementById('mouthOpenOverlay');
            const mouthClosed = document.getElementById('mouthClosedOverlay');
            const portraitWrap = document.getElementById('portraitWrap');
            const stageArea = document.getElementById('stageArea');
            const recBtnTop = document.getElementById('recBtnTop');
            const recIndicator = document.getElementById('recIndicator');
            const recIndicatorLabel = document.getElementById('recIndicatorLabel');
            const playPauseButton = document.getElementById('playPauseButton');
            const player = document.getElementById('player');
            const saveBtn = document.getElementById('saveBtn');
            const galleryList = document.getElementById('galleryList');
            const recordCanvas = document.getElementById('recordCanvas');
            
            // NEW OVERLAY DOM
            const playerOverlay = document.getElementById('playerOverlay');
            const galleryVideoPlayer = document.getElementById('galleryVideoPlayer');
            const closeOverlayBtn = document.getElementById('closeOverlayBtn');
            const overlayVideoName = document.getElementById('overlayVideoName');
            
            // ─── STATE ───
            let audioContext, audioBuffer, sourceNode, analyserNode, audioDestinationNode;
            let isPlaying = false,
                isRecording = false;
            let mediaRecorder, recordedChunks = [],
                animFrame;
            let canvasStream = null,
                canvasTrack = null;
            let recordedBlob = null;
            // Lip values
            const lipX = document.getElementById('lipX');
            const lipY = document.getElementById('lipY');
            const lipScale = document.getElementById('lipScale');
            // ─── LIP POSITION ───
            function updateLips() {
                mouthOverlay.style.setProperty('--lip-x', lipX.value + 'px');
                mouthOverlay.style.setProperty('--lip-y', lipY.value + 'px');
                mouthOverlay.style.setProperty('--lip-scale', lipScale.value / 100);
            }
            [lipX, lipY, lipScale].forEach(el => el.addEventListener('input', updateLips));
            // ─── FACE UPLOAD ───
            faceInput.addEventListener('change', (e) => {
                const file = e.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = (ev) => faceImage.src = ev.target.result;
                    reader.readAsDataURL(file);
                }
            });
            // ─── AUDIO UPLOAD ───
            audioInput.addEventListener('change', async (e) => {
                const file = e.target.files[0];
                if (file) {
                    try {
                        if (!audioContext) audioContext = new(window.AudioContext || window.webkitAudioContext)();
                        const arrayBuffer = await file.arrayBuffer();
                        audioBuffer = await audioContext.decodeAudioData(arrayBuffer);
                        player.classList.add('is-visible');
                        showToast('🎵 Audio loaded: ' + file.name, 'success');
                    } catch (err) {
                        showToast('⚠️ Could not decode audio: ' + err.message, 'error');
                    }
                }
            });
            // ─── LIP SYNC ANIMATION ───
            function animateFace() {
                if (!isPlaying || !analyserNode) return;
                const samples = new Uint8Array(analyserNode.fftSize);
                analyserNode.getByteTimeDomainData(samples);
                let energy = 0;
                for (const s of samples) {
                    const norm = (s - 128) / 128;
                    energy += norm * norm;
                }
                const rms = Math.sqrt(energy / samples.length);
                const open = Math.min(1, Math.max(0, (rms - 0.01) * 8));
                mouthOpen.style.opacity = open;
                mouthClosed.style.opacity = 1 - open;
                portraitWrap.style.transform = `scale(${1 + open * 0.02})`;
                animFrame = requestAnimationFrame(animateFace);
            }
            // ─── PLAY / PAUSE AUDIO ───
            playPauseButton.addEventListener('click', () => {
                if (isPlaying) {
                    sourceNode?.stop();
                    isPlaying = false;
                    playPauseButton.textContent = "▶ Play Audio";
                    mouthOpen.style.opacity = 0;
                    mouthClosed.style.opacity = 1;
                    cancelAnimationFrame(animFrame);
                    return;
                }
                if (!audioBuffer) {
                    showToast('⚠️ Please upload an audio file first.', 'error');
                    return;
                }
                try {
                    if (audioContext.state === 'suspended') audioContext.resume();
                    sourceNode = audioContext.createBufferSource();
                    analyserNode = audioContext.createAnalyser();
                    audioDestinationNode = audioContext.createMediaStreamDestination();
                    sourceNode.buffer = audioBuffer;
                    analyserNode.fftSize = 256;
                    sourceNode.connect(analyserNode);
                    sourceNode.connect(audioContext.destination);
                    sourceNode.connect(audioDestinationNode);
                    sourceNode.start(0);
                    isPlaying = true;
                    playPauseButton.textContent = "⏸ Pause Audio";
                    animateFace();
                    sourceNode.onended = () => {
                        isPlaying = false;
                        playPauseButton.textContent = "▶ Play Audio";
                        mouthOpen.style.opacity = 0;
                        mouthClosed.style.opacity = 1;
                    };
                } catch (err) {
                    showToast('⚠️ Playback error: ' + err.message, 'error');
                }
            });
            // ─── CANVAS DRAWING ───
            const ctx = recordCanvas.getContext('2d');
            function drawStageToCanvas() {
                const w = 380,
                    h = 470;
                ctx.clearRect(0, 0, w, h);
                // Background
                const grad = ctx.createLinearGradient(0, 0, 0, h);
                grad.addColorStop(0, '#3f7568');
                grad.addColorStop(1, '#1f3f38');
                ctx.fillStyle = grad;
                ctx.fillRect(0, 0, w, h);
                // Draw face
                const img = faceImage;
                if (img.complete && img.naturalWidth > 0) {
                    const aspect = img.naturalWidth / img.naturalHeight;
                    let drawW = w * 0.85;
                    let drawH = drawW / aspect;
                    if (drawH > h * 0.75) {
                        drawH = h * 0.75;
                        drawW = drawH * aspect;
                    }
                    const x = (w - drawW) / 2;
                    const y = (h - drawH) / 2 - 20;
                    ctx.save();
                    ctx.beginPath();
                    if (ctx.roundRect) {
                        ctx.roundRect(x, y, drawW, drawH, 16);
                    } else {
                        ctx.rect(x, y, drawW, drawH);
                    }
                    ctx.clip();
                    ctx.drawImage(img, x, y, drawW, drawH);
                    ctx.restore();
                } else {
                    ctx.fillStyle = '#2a4a42';
                    ctx.beginPath();
                    ctx.arc(w / 2, h / 2 - 20, 70, 0, 2 * Math.PI);
                    ctx.fill();
                    ctx.fillStyle = '#9aa8a2';
                    ctx.font = '24px system-ui';
                    ctx.textAlign = 'center';
                    ctx.fillText('Upload Face', w / 2, h / 2 + 40);
                }
                // Mouth
                const lipXVal = parseFloat(lipX.value) || 0;
                const lipYVal = parseFloat(lipY.value) || 0;
                const lipScaleVal = (parseFloat(lipScale.value) || 100) / 100;
                const mouthX = w / 2 + lipXVal * 0.6;
                const mouthY = h - 80 + lipYVal * 0.6;
                const mouthW = 80 * lipScaleVal;
                const mouthH = 30 * lipScaleVal;
                // closed mouth
                ctx.strokeStyle = '#803328';
                ctx.lineWidth = 6;
                ctx.lineCap = 'round';
                ctx.beginPath();
                ctx.moveTo(mouthX - mouthW * 0.4, mouthY - 4);
                ctx.quadraticCurveTo(mouthX, mouthY - 12, mouthX + mouthW * 0.4, mouthY - 4);
                ctx.stroke();
                ctx.beginPath();
                ctx.moveTo(mouthX - mouthW * 0.35, mouthY - 2);
                ctx.quadraticCurveTo(mouthX, mouthY + 4, mouthX + mouthW * 0.35, mouthY - 2);
                ctx.stroke();
                // open mouth overlay
                const openVal = parseFloat(mouthOpen.style.opacity) || 0;
                if (openVal > 0.05) {
                    ctx.save();
                    ctx.globalAlpha = Math.min(openVal, 1);
                    ctx.fillStyle = '#42130e';
                    ctx.beginPath();
                    ctx.ellipse(mouthX, mouthY + 4, mouthW * 0.5, mouthH * 0.5, 0, 0, 2 * Math.PI);
                    ctx.fill();
                    ctx.fillStyle = '#ffffff';
                    ctx.beginPath();
                    ctx.ellipse(mouthX, mouthY - 2, mouthW * 0.35, mouthH * 0.2, 0, 0, 2 * Math.PI);
                    ctx.fill();
                    ctx.fillStyle = '#c95b53';
                    ctx.beginPath();
                    ctx.ellipse(mouthX, mouthY + 8, mouthW * 0.3, mouthH * 0.25, 0, 0, 2 * Math.PI);
                    ctx.fill();
                    ctx.restore();
                }
                // ticker
                ctx.fillStyle = 'rgba(191,77,60,0.92)';
                ctx.fillRect(0, h - 28, w, 28);
                ctx.fillStyle = '#e9b949';
                ctx.font = 'bold 10px system-ui';
                ctx.fillText('BREAKING NEWS  |  तामीर अली विस्फोटक न्यूज़', 10, h - 8);
            }
            let drawInterval = null;
            function startCanvasDraw() {
                if (drawInterval) return;
                drawInterval = setInterval(drawStageToCanvas, 33);
            }
            function stopCanvasDraw() {
                if (drawInterval) {
                    clearInterval(drawInterval);
                    drawInterval = null;
                }
            }
            // ─── RECORD BUTTON ───
            recBtnTop.addEventListener('click', async () => {
                if (isRecording) {
                    stopRecording();
                    return;
                }
                try {
                    startCanvasDraw();
                    canvasStream = recordCanvas.captureStream(30);
                    canvasTrack = canvasStream.getVideoTracks()[0];
                    let audioTrack = null;
                    if (audioDestinationNode && audioDestinationNode.stream.getAudioTracks().length > 0) {
                        audioTrack = audioDestinationNode.stream.getAudioTracks()[0];
                    }
                    const tracks = [canvasTrack];
                    if (audioTrack) tracks.push(audioTrack);
                    const combinedStream = new MediaStream(tracks);
                    // Try preferred codec, fallback to webm
                    let mimeType = 'video/webm;codecs=vp9,opus';
                    if (!MediaRecorder.isTypeSupported(mimeType)) {
                        mimeType = 'video/webm;codecs=vp8,opus';
                        if (!MediaRecorder.isTypeSupported(mimeType)) {
                            mimeType = 'video/webm';
                        }
                    }
                    mediaRecorder = new MediaRecorder(combinedStream, { mimeType: mimeType });
                    recordedChunks = [];
                    mediaRecorder.ondataavailable = e => {
                        if (e.data.size > 0) recordedChunks.push(e.data);
                    };
                    mediaRecorder.onstop = () => {
                        const blob = new Blob(recordedChunks, { type: mimeType });
                        recordedBlob = blob;
                        saveBtn.disabled = false;
                        saveBtn.classList.add('has-video');
                        saveBtn.textContent = '💾 Save Video to Gallery';
                        recBtnTop.innerHTML = 
                            `<span class="dot"></span><span>Record</span><span class="badge">● Live</span>`;
                        recBtnTop.classList.remove('recording');
                        recIndicator.classList.remove('active');
                        recIndicatorLabel.textContent = "IDLE";
                        stopCanvasDraw();
                        if (canvasTrack) canvasTrack.stop();
                        canvasTrack = null;
                        canvasStream = null;
                        isRecording = false;
                        showToast('✅ Recording finished! Tap Save to store.', 'success');
                    };
                    mediaRecorder.start(1000);
                    isRecording = true;
                    recBtnTop.innerHTML = `<span class="dot"></span><span>Stop</span><span class="badge">● REC</span>`;
                    recBtnTop.classList.add('recording');
                    recIndicator.classList.add('active');
                    recIndicatorLabel.textContent = "REC";
                    saveBtn.disabled = true;
                    saveBtn.classList.remove('has-video');
                } catch (err) {
                    showToast('⚠️ Recording error: ' + err.message, 'error');
                    stopCanvasDraw();
                    if (canvasTrack) canvasTrack.stop();
                    canvasTrack = null;
                    canvasStream = null;
                    isRecording = false;
                    recBtnTop.innerHTML = 
                        `<span class="dot"></span><span>Record</span><span class="badge">● Live</span>`;
                    recBtnTop.classList.remove('recording');
                    recIndicator.classList.remove('active');
                    recIndicatorLabel.textContent = "IDLE";
                }
            });
            function stopRecording() {
                if (mediaRecorder && isRecording) {
                    mediaRecorder.stop();
                } else {
                    isRecording = false;
                    recBtnTop.innerHTML = 
                        `<span class="dot"></span><span>Record</span><span class="badge">● Live</span>`;
                    recBtnTop.classList.remove('recording');
                    recIndicator.classList.remove('active');
                    recIndicatorLabel.textContent = "IDLE";
                    stopCanvasDraw();
                    if (canvasTrack) canvasTrack.stop();
                    canvasTrack = null;
                    canvasStream = null;
                }
            }
            // ─── SAVE BUTTON — uses localStorage (fixes IndexedDB error) ───
            saveBtn.addEventListener('click', async () => {
                if (!recordedBlob) {
                    showToast('No video to save. Record first.', 'error');
                    return;
                }
                try {
                    const name = 'VisfotNews_' + Date.now() + '.webm';
                    // Convert blob to base64 for localStorage
                    const base64 = await blobToBase64(recordedBlob);
                    // Get existing videos from localStorage
                    let videos = [];
                    try {
                        const stored = localStorage.getItem('visfot_videos');
                        if (stored) videos = JSON.parse(stored);
                    } catch (e) { videos = []; }
                    const entry = {
                        id: Date.now(),
                        name: name,
                        data: base64,
                        size: recordedBlob.size,
                        timestamp: new Date().toLocaleString()
                    };
                    videos.push(entry);
                    localStorage.setItem('visfot_videos', JSON.stringify(videos));
                    showToast('✅ Video saved to gallery!', 'success');
                    renderGallery();
                    // Also trigger download as backup
                    const url = URL.createObjectURL(recordedBlob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = name;
                    a.click();
                    setTimeout(() => URL.revokeObjectURL(url), 5000);
                    // Reset save button state
                    saveBtn.disabled = true;
                    saveBtn.classList.remove('has-video');
                    recordedBlob = null;
                } catch (err) {
                    showToast('⚠️ Save error: ' + err.message, 'error');
                    // Fallback: direct download
                    try {
                        const url = URL.createObjectURL(recordedBlob);
                        const a = document.createElement('a');
                        a.href = url;
                        a.download = 'VisfotNews_' + Date.now() + '.webm';
                        a.click();
                        setTimeout(() => URL.revokeObjectURL(url), 5000);
                        showToast('💾 Video downloaded instead (storage unavailable)', 'info');
                    } catch (e2) {
                        showToast('❌ Could not save or download video.', 'error');
                    }
                }
            });
            // ─── HELPERS ───
            function blobToBase64(blob) {
                return new Promise((resolve, reject) => {
                    const reader = new FileReader();
                    reader.onload = () => resolve(reader.result);
                    reader.onerror = () => reject(reader.error);
                    reader.readAsDataURL(blob);
                });
            }
            function base64ToBlob(base64) {
                const parts = base64.split(',');
                const mime = parts[0].match(/:(.*?);/)[1];
                const byteString = atob(parts[1]);
                const ab = new ArrayBuffer(byteString.length);
                const ia = new Uint8Array(ab);
                for (let i = 0; i < byteString.length; i++) {
                    ia[i] = byteString.charCodeAt(i);
                }
                return new Blob([ab], { type: mime });
            }
            // ─── RENDER GALLERY ───
            function renderGallery() {
                let videos = [];
                try {
                    const stored = localStorage.getItem('visfot_videos');
                    if (stored) videos = JSON.parse(stored);
                } catch (e) { videos = []; }
                if (!videos || videos.length === 0) {
                    galleryList.innerHTML = `<div class="empty-gallery">No saved videos yet.</div>`;
                    return;
                }
                let html = '';
                // Show newest first
                const sorted = [...videos].reverse();
                for (const item of sorted) {
                    const sizeMB = (item.size / 1024 / 1024).toFixed(1);
                    const displayName = item.name.length > 28 ? item.name.slice(0, 25) + '…' : item.name;
                    html += `
                        <div class="gallery-item">
                            <span class="name">📹 ${displayName} (${sizeMB} MB)</span>
                            <div class="actions">
                                <button class="play-btn" data-id="${item.id}">▶</button>
                                <button class="del-btn" data-id="${item.id}">✕</button>
                            </div>
                        </div>
                    `;
                }
                galleryList.innerHTML = html;
                
                // ✅ Play (OPEN OVERLAY INSTEAD OF NEW WINDOW)
                galleryList.querySelectorAll('.play-btn').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        const id = Number(e.target.dataset.id);
                        const found = videos.find(v => v.id === id);
                        if (found) {
                            try {
                                const blob = base64ToBlob(found.data);
                                const url = URL.createObjectURL(blob);
                                
                                // Open Overlay
                                openVideoOverlay(found.name, url);
                                
                            } catch (err) {
                                showToast('⚠️ Could not play video: ' + err.message, 'error');
                            }
                        }
                    });
                });
                // Delete
                galleryList.querySelectorAll('.del-btn').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        const id = Number(e.target.dataset.id);
                        if (!confirm('Delete this video?')) return;
                        let updated = videos.filter(v => v.id !== id);
                        localStorage.setItem('visfot_videos', JSON.stringify(updated));
                        renderGallery();
                        showToast('🗑️ Video deleted', 'info');
                    });
                });
            }
            
            // ─── ✅ NEW OVERLAY PLAYER HELPERS ───
            function openVideoOverlay(name, url) {
                overlayVideoName.textContent = name;
                galleryVideoPlayer.src = url;
                playerOverlay.classList.add('is-visible');
                // Auto play
                galleryVideoPlayer.play().catch(e => {
                    console.log("Auto-play blocked, user must interact");
                });
            }
            function closeVideoOverlay() {
                galleryVideoPlayer.pause();
                galleryVideoPlayer.src = ""; // Stop buffering
                playerOverlay.classList.remove('is-visible');
            }
            closeOverlayBtn.addEventListener('click', closeVideoOverlay);
            // Also close if tapping background (not video controls)
            playerOverlay.addEventListener('click', (e) => {
                if (e.target === playerOverlay) closeVideoOverlay();
            });
            
            // ─── TOAST ───
            function showToast(msg, type = 'info') {
                const existing = document.querySelector('.toast-msg');
                if (existing) existing.remove();
                const div = document.createElement('div');
                div.className = 'toast-msg ' + type;
                div.textContent = msg;
                document.body.appendChild(div);
                setTimeout(() => {
                    div.style.opacity = '0';
                    setTimeout(() => div.remove(), 400);
                }, 3500);
            }
            // ─── INIT ───
            renderGallery();
            startCanvasDraw();
            // ─── ROUND RECT POLYFILL ───
            if (!CanvasRenderingContext2D.prototype.roundRect) {
                CanvasRenderingContext2D.prototype.roundRect = function(x, y, w, h, r) {
                    if (r > w / 2) r = w / 2;
                    if (r > h / 2) r = h / 2;
                    this.moveTo(x + r, y);
                    this.arcTo(x + w, y, x + w, y + h, r);
                    this.arcTo(x + w, y + h, x, y + h, r);
                    this.arcTo(x, y + h, x, y, r);
                    this.arcTo(x, y, x + w, y, r);
                    this.closePath();
                    return this;
                };
            }
            // ─── CLEANUP ───
            window.addEventListener('beforeunload', () => {
                stopCanvasDraw();
                if (canvasTrack) canvasTrack.stop();
                if (mediaRecorder && isRecording) mediaRecorder.stop();
                if (galleryVideoPlayer.src) {
                    URL.revokeObjectURL(galleryVideoPlayer.src);
                }
            });
        })();
    </script>
</body>
</html>
