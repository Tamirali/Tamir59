                <img id="faceImage" src="data:image/svg+xml,%3Csvg xmlns='[http://www.w3.org/2000/svg](http://www.w3.org/2000/svg)' viewBox='0 0 380 470'%3E%3Crect width='380' height='470' fill='%231b2a26'/%3E%3Ccircle cx='190' cy='180' r='70' fill='%233a5a52'/%3E%3Ctext x='190' y='310' font-family='system-ui' font-size='24' fill='%239aa8a2' text-anchor='middle'%3EUpload Face%3C/text%3E%3C/svg%3E" alt="Face" />
                <div class="mouth-overlay" id="mouthOverlay">
                    <svg viewBox="0 0 120 60">
