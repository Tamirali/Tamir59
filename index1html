            bottom: calc(18% + 38px + var(--lip-y));
            width: calc(28% * var(--lip-scale));
            height: calc(9% * var(--lip-scale));
            transform: translateX(-50%);
            z-index: 3;
        }
        .mouth-overlay svg {
            width: 100%;
            height: 100%;
        }
        #mouthOpenOverlay {
            opacity: 0;
            transform-origin: center;
        }
        #mouthClosedOverlay {
            opacity: 1;
            transform-origin: center;
        }
        .news-ticker {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            background: var(--red);
            color: #fff;
            display: flex;
            align-items: center;
            font-size: 0.75rem;
            font-weight: bold;
            overflow: hidden;
            border-top: 2px solid var(--gold);
        }
        .ticker-title {
            background: var(--gold);
            color: #000;
            padding: 4px 10px;
            white-space: nowrap;
            z-index: 2;
        }
        .ticker-text {
            white-space: nowrap;
            padding-left: 100%;
            display: inline-block;
            animation: marquee 12s linear infinite;
        }
        @keyframes marquee {
            0% {
                transform: translate(0, 0);
            }
            100% {
                transform: translate(-100%, 0);
            }
        }
        /* ─── PANEL ─── */
        .panel {
            flex: 1;
            display: flex;
            flex-direction: column;
            padding: 16px;
            background: var(--paper);
            overflow-y: auto;
            gap: 12px;
        }
        .controls-box {
            padding: 12px;
            border: 1px solid rgba(23, 51, 47, 0.1);
            border-radius: 12px;
            background: rgba(255, 253, 247, 0.7);
        }
        .slider-group {
            display: flex;
            gap: 8px;
            margin-top: 8px;
        }
        .slider-item {
            flex: 1;
            font-size: 0.65rem;
        }
        .slider-item input {
            width: 100%;
        }
        .upload-zone {
            border: 1.5px dashed #9a8d79;
            padding: 12px;
            text-align: center;
            border-radius: 8px;
            cursor: pointer;
            transition: background 0.2s;
            font-size: 0.9rem;
        }
        .upload-zone:hover {
            background: rgba(154, 141, 121, 0.06);
        }
        .player {
            display: none;
            margin-top: 8px;
        }
        .player.is-visible {
            display: block;
