        .gallery-item .name {
            flex: 1;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .gallery-item .actions {
            display: flex;
            gap: 4px;
            flex-shrink: 0;
        }
        .gallery-item button {
            background: var(--red);
            color: #fff;
            padding: 2px 12px;
            border-radius: 20px;
            font-size: 0.6rem;
