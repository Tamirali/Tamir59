            }
            .rec-indicator {
                display: none;
            }
        }
    </style>
</head>
<body>
    <main class="shell">
        <!-- ─── STAGE AREA (NEWS FRAME) ─── -->
        <section class="stage" id="stageArea">
            <header class="stage-mark">
                <h1>📰 तामीर अली विस्फोटक न्यूज़</h1>
